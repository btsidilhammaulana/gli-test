<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer_youtube"
      android:layout_width="match_parent"
      android:layout_height="216dp"
      app:layout_constraintTop_toTopOf="parent" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer1"
      android:layout_width="152dp"
      android:layout_height="0dp"
      android:layout_marginVertical="@dimen/spacing_xs"
      android:layout_marginStart="@dimen/spacing"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintDimensionRatio="3:4"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer_youtube" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer2"
      android:layout_width="0dp"
      android:layout_height="24dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginVertical="@dimen/spacing_xs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toEndOf="@id/shimmer1"
      app:layout_constraintTop_toTopOf="@id/shimmer1" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer3"
      android:layout_width="72dp"
      android:layout_height="12dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginVertical="@dimen/spacing_xs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toEndOf="@id/shimmer1"
      app:layout_constraintTop_toBottomOf="@id/shimmer2" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer4"
      android:layout_width="30dp"
      android:layout_height="16dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginVertical="@dimen/spacing_xs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toEndOf="@id/shimmer1"
      app:layout_constraintTop_toBottomOf="@id/shimmer3" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer5"
      android:layout_width="152dp"
      android:layout_height="16dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginVertical="@dimen/spacing_xs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toEndOf="@id/shimmer1"
      app:layout_constraintTop_toBottomOf="@id/shimmer4" />

  <LinearLayout
      android:layout_width="0dp"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toEndOf="@id/shimmer1"
      app:layout_constraintTop_toBottomOf="@id/shimmer5">

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="32dp"
        android:layout_marginVertical="@dimen/spacing_xs"
        android:layout_marginStart="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xs" />

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="32dp"
        android:layout_marginVertical="@dimen/spacing_xs"
        android:layout_marginStart="@dimen/spacing_xs"
        app:corner_radius="@dimen/border_radius_xs" />

  </LinearLayout>

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer6"
      android:layout_width="12dp"
      android:layout_height="24dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginTop="@dimen/spacing"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer1" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer7"
      android:layout_width="0dp"
      android:layout_height="16dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginTop="@dimen/spacing_xxs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer6" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer8"
      android:layout_width="0dp"
      android:layout_height="16dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginTop="@dimen/spacing_xxs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintEnd_toEndOf="parent"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer7" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer9"
      android:layout_width="216dp"
      android:layout_height="16dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginTop="@dimen/spacing_xxs"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer8" />

  <com.gli.custom.shimmer.ShimmerView
      android:id="@+id/shimmer10"
      android:layout_width="78dp"
      android:layout_height="24dp"
      android:layout_marginHorizontal="@dimen/spacing"
      android:layout_marginTop="@dimen/spacing"
      app:corner_radius="@dimen/border_radius_xs"
      app:layout_constraintStart_toStartOf="parent"
      app:layout_constraintTop_toBottomOf="@id/shimmer9" />

  <LinearLayout
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      app:layout_constraintTop_toBottomOf="@id/shimmer10">

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="@dimen/spacing"
        android:layout_marginTop="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xl" />

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="@dimen/spacing_xs"
        android:layout_marginTop="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xl" />

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="@dimen/spacing_xs"
        android:layout_marginTop="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xl" />

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="@dimen/spacing_xs"
        android:layout_marginTop="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xl" />

    <com.gli.custom.shimmer.ShimmerView
        android:layout_width="72dp"
        android:layout_height="72dp"
        android:layout_marginHorizontal="@dimen/spacing_xs"
        android:layout_marginTop="@dimen/spacing"
        app:corner_radius="@dimen/border_radius_xl" />

  </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>